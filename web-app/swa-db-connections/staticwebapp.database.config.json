{
  "$schema": "https://raw.githubusercontent.com/Azure/data-api-builder/main/schemas/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "options": {
      "set-session-context": false
    },
    "connection-string": "@env('DATABASE_CONNECTION_STRING')"
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/rest"
    },
    "graphql": {
      "allow-introspection": true,
      "enabled": true,
      "path": "/graphql"
    },
    "host": {
      "mode": "production",
      "cors": {
        "allow-credentials": false,
        "origins": [
          "http://localhost:3000",
          "http://localhost:5173",
          "http://127.0.0.1:3000",
          "http://127.0.0.1:5173"
        ]
      },
      "authentication": {
        "provider": "StaticWebApps"
      }
    }
  },
  "entities": {
    "UserAccess": {
      "source": "dbo.UserAccess",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "AccessRoles": {
      "source": "dbo.AccessRoles", 
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "Product": {
      "source": "dbo.Product",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "ContainerSpecs": {
      "source": "dbo.ContainerSpecs",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "InventoryStocks": {
      "source": "dbo.InventoryStocks",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "PR": {
      "source": "dbo.PR",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "Warehouse": {
      "source": "dbo.warehouse",
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            { "action": "read" },
            { "action": "create" },
            { "action": "update" },
            { "action": "delete" }
          ]
        }
      ]
    },
    "ProcurementPlan": {
      "source": "dbo.ProcurementPlan",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "Supplier": {
      "source": "dbo.supplier",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "Sales": {
      "source": "dbo.sales",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    },
    "ComplaintIssue": {
      "source": "dbo.ComplaintIssue",
      "permissions": [
        {
          "actions": ["*"],
          "role": "anonymous"
        }
      ]
    }
  }
}